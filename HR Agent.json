    {
      "parameters": {
        "jsCode": "const empleado = $('Get a row').first().json;\nconst hoy = new Date().toLocaleDateString('es-CO', { \n  year: 'numeric', \n  month: 'long', \n  day: 'numeric' \n});\n\nconst html = `<html>\n<body style=\"font-family: Arial; padding: 60px; color: #333; line-height: 1.8;\">\n\n  <br><br>\n\n  <p style=\"text-align: center; font-weight: bold; font-size: 14px;\">\n    TRUORA S.A.S. - NIT 901189979-5\n  </p>\n\n  <br>\n\n  <p style=\"text-align: center; font-weight: bold; font-size: 14px;\">\n    CERTIFICA\n  </p>\n\n  <br><br>\n\n  <p style=\"text-align: justify; font-size: 13px;\">\n    Que <strong>${empleado.nombre}</strong>, con cédula de ciudadanía No. \n    <strong>${empleado.cedula}</strong>, trabaja en la empresa Truora S.A.S., \n    con domicilio en Bogotá, Colombia, <strong>desde el ${empleado.fecha_ingreso}</strong>, \n    desempeñando el cargo de <strong>${empleado.cargo}</strong>. \n    Se encuentra vinculado mediante un contrato de trabajo \n    <strong>${empleado.tipo_contrato}</strong>, recibe un salario mensual bruto de \n    <strong>COP ${Number(empleado.salario).toLocaleString('es-CO')}</strong>\n  </p>\n\n  <br><br>\n\n  <p style=\"text-align: justify; font-size: 13px;\">\n    La presente certificación se expide a solicitud del trabajador en \n    ${empleado.ciudad}, el día <strong>${hoy}</strong>\n  </p>\n\n  <br><br><br>\n\n  <p style=\"font-size: 13px;\"><strong>David Giraldo Gaviria</strong></p>\n  <p style=\"font-size: 13px;\"><strong>Head of People</strong></p>\n  <p style=\"font-size: 13px;\">dgiraldo@truora.com</p>\n  <p style=\"font-size: 13px;\">C.C 1214733501</p>\n  <p style=\"font-size: 13px;\">Tel: +57 3043358722</p>\n\n</body>\n</html>`;\n\nreturn [{\n  json: {\n    html: html\n  }\n}];"
      },
