      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst rawText = input.output[0].content[0].text;\n\n// Limpia backticks de markdown si los hay\nconst text = rawText.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\n\nlet parsed;\ntry {\n  parsed = JSON.parse(text);\n} catch (e) {\n  parsed = {\n    tipo: \"error\",\n    subtipo: \"parse_error\",\n    datos: {},\n    respuesta: \"Disculpa, no entendí tu solicitud. ¿Puedes reformularla?\"\n  };\n}\n\nreturn [{\n  json: {\n    tipo: parsed.tipo,\n    subtipo: parsed.subtipo,\n    datos: parsed.datos,\n    respuesta: parsed.respuesta,\n    telegram_id: $('Telegram Trigger').first().json.message.from.id.toString(),\n    nombre_usuario: $('Telegram Trigger').first().json.message.from.first_name\n  }\n}];"
      },
